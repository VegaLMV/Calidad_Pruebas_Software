              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 401\", function () { pm.expect(pm.response.code).to.be.oneOf([400, 401]); });",
                  "pm.test(\"Mensaje indica revocación\", function () { pm.expect(pm.response.text()).to.include(\"inválido\"); });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"a1c7d84e-cdb8-43a9-b0b1-88a40d8e58bc\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh-token",
