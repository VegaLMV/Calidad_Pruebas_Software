              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Emite un nuevo JWT\", function () { pm.expect(pm.response.json()).to.have.property('token'); });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
