  "item": [
    {
      "name": "1. Autenticación y Seguridad (/login)",
      "item": [
        {
          "name": "1.1 [Happy Path] Login SuperAdmin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200\", function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Contiene token y refreshToken\", function () {",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData).to.have.property('refreshToken');",
                  "});",
                  "pm.environment.set(\"admin_token\", jsonData.token);",
                  "pm.environment.set(\"valid_refresh_token\", jsonData.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"KantusAdmin123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesión con el administrador. Guarda el JWT dinámicamente para las siguientes peticiones."
          },
          "response": []
        },
        {
          "name": "1.2 [Seguridad] Contraseña Incorrecta (Fuerza Bruta)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 401 Unauthorized\", function () { pm.expect(pm.response.code).to.be.oneOf([400, 401]); });",
                  "pm.test(\"Mensaje de error no revela existencia del usuario\", function () { pm.expect(pm.response.text()).to.include(\"incorrectos\"); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"ClaveEquivocada999\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.3 [Seguridad] Usuario Inexistente (OSINT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 401 Unauthorized\", function () { pm.expect(pm.response.code).to.be.oneOf([400, 401, 404]); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hacker_mozo_falso\",\n  \"password\": \"12345\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Pruebas centradas en el acceso y protección contra fuerza bruta."
    },
    {
      "name": "2. Ciclo de Vida de Sesiones (/refresh-token)",
